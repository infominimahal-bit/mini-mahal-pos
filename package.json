{
  "name": "zaynahs-pos",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron.cjs",
  "description": "A modern POS system built with React and Supabase",
  "keywords": [
    "react",
    "supabase",
    "pos",
    "point-of-sale",
    "system",
    "ecommerce"
  ],
  "author": "Shoaib zaynah <zaynahspos@gmail.com> (https://zaynahspos.com)",
  "scripts": {
    "dev": "vite --host",
    "electron:dev": "concurrently \"vite --host\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "build:win": "vite build --mode electron && electron-builder --win --x64",
    "build:mac": "vite build --mode electron && electron-builder --mac",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.zaynah.pos",
    "productName": "ZaynahsPos",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "preload.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/logo.png",
        "to": "logo.png"
      },
      {
        "from": "public/sqlite3.wasm",
        "to": "sqlite3.wasm"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/logo.ico",
      "forceCodeSigning": false,
      "verifyUpdateCodeSignature": false
    },
    "mac": {
      "target": "dmg",
      "icon": "public/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/logo.ico",
      "uninstallerIcon": "public/logo.ico",
      "installerHeaderIcon": "public/logo.ico"
    }
  },
  "dependencies": {
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/auth-helpers-react": "^0.5.0",
    "@supabase/auth-ui-react": "^0.4.7",
    "@supabase/auth-ui-shared": "^0.1.8",
    "@supabase/supabase-js": "^2.103.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/jsbarcode": "^3.11.4",
    "clsx": "^2.1.1",
    "date-fns": "^2.30.0",
    "dexie": "^4.4.2",
    "electron-store": "^11.0.2",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.344.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-barcode": "^1.6.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.20.1",
    "react-to-print": "^3.3.0",
    "recharts": "^2.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-basic-ssl": "^1.1.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.21",
    "wait-on": "^9.0.4"
  }
}
